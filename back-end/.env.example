#####################################################################
# Connecttr backend (.env)
# - Copy to `back-end/.env` and fill values.
# - Do NOT commit real secrets.
#####################################################################

#####################################################################
# App environment
#####################################################################
# Set to "production" on Render/real deploys. Leave unset for local dev.
ENV=development

#####################################################################
# Public URLs (required in production; defaulted locally)
#####################################################################
# Public backend URL used for OAuth callback construction and links.
BACKEND_PUBLIC_URL=http://127.0.0.1:8010

# Frontend origin used for CORS + redirects back to the SPA.
FRONTEND_ORIGIN=http://127.0.0.1:3000

#####################################################################
# MongoDB
#####################################################################
# Required: backend currently raises if missing.
# Local example (if you have MongoDB running locally):
# MONGO_URI=mongodb://127.0.0.1:27017
MONGO_URI=

# Optional (defaults to "kodingbolte_db")
MONGO_DB_NAME=kodingbolte_db

#####################################################################
# Google OAuth (Login)
#####################################################################
# Required to complete /auth/login/google flow.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SECRET_KEY=

# In Google Cloud Console, set Authorized redirect URI to:
# http://127.0.0.1:8010/auth/callback/google

#####################################################################
# Scrape.do (Lead discovery)
#####################################################################
# Primary Scrape.do token used by the backend.
# Older code paths may still fall back to SCRAPE_DO_TOKEN, but standardize on this key.
SCRAPEDO_TOKEN=

#####################################################################
# Perplexity (LLM features: brief analysis, intent classifier, reply classifier)
#####################################################################
PERPLEXITY_API_KEY=
# Optional
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar

# Optional network timeout used by the Perplexity client
REQUEST_TIMEOUT_SECONDS=30

#####################################################################
# Postmark (Email sending + webhooks)
#####################################################################
POSTMARK_TOKEN=
POSTMARK_BROADCAST=broadcast
INBOUND_DOMAIN=reply.yourdomain.com
POSTMARK_FROM_EMAIL=support@connecttr.com

#####################################################################
# Optional: internal self-call base (Render or local)
#####################################################################
# Defaults to localhost:8000 if not set; use this with start-local.bat.
EMAILHUB_URL=http://127.0.0.1:8010

# Local-only: set true if you need localhost to inspect legacy/demo Email Hub
# records across old audit org buckets. Do not set this on Render.
EMAILHUB_INCLUDE_LEGACY_DATA=false

#####################################################################
# Internal endpoint protection
#####################################################################
# Used by /pipeline endpoints. Set a long random string in real environments.
API_SECRET=
